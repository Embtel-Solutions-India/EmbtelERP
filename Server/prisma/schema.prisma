generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ASSIGNMENT_CHANGE
  PERSPECTIVE_SWITCH
  LOGIN
  LOGOUT
}

enum PerspectiveType {
  SELF
  DESCENDANT
  BUSINESS
  DEPARTMENT
  TEAM
  ALL
}

enum PerspectiveTargetType {
  ORGANIZATION
  BUSINESS
  DEPARTMENT
  TEAM
  EMPLOYEE
}

enum MarketingCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum MarketingTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum MarketingLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum MarketingActivityType {
  SOCIAL_MEDIA
  LEAD_GENERATION
  DAILY_REPORT
  TASK_UPDATE
  CAMPAIGN_UPDATE
  OTHER
}

enum MarketingKPIType {
  LEADS_GENERATED
  CAMPAIGN_SUCCESS
  TASK_COMPLETION
  PRODUCTIVITY
  BUDGET_UTILIZATION
  CUSTOM
}

model Organization {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  businesses Business[]
  employees  Employee[]
  marketingCampaigns MarketingCampaign[]
  marketingTasks     MarketingTask[]
  marketingLeads     MarketingLead[]
  marketingActivities MarketingActivity[]
  marketingKPIs      MarketingKPI[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Business {
  id             String       @id @default(cuid())
  organizationId  String
  name           String
  code           String       @unique
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  departments    Department[]
  teams          Team[]
  employees      Employee[]
  notifications  Notification[] @relation("NotificationBusiness")
  tasks          Task[]
  documents     Document[]
  activities    Activity[]
  auditLogs     AuditLog[]
  marketingCampaigns MarketingCampaign[]
  marketingTasks     MarketingTask[]
  marketingLeads     MarketingLead[]
  marketingActivities MarketingActivity[]
  marketingKPIs      MarketingKPI[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Department {
  id              String       @id @default(cuid())
  businessId      String
  name            String
  code            String
  parentId        String?
  isActive        Boolean      @default(true)
  business        Business     @relation(fields: [businessId], references: [id])
  parent          Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children        Department[] @relation("DepartmentTree")
  teams           Team[]
  employees       Employee[]
  tasks           Task[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([businessId, code])
}

model Team {
  id           String      @id @default(cuid())
  businessId   String
  departmentId String?
  name         String
  code         String
  isActive     Boolean     @default(true)
  business     Business    @relation(fields: [businessId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  tasks        Task[]
  marketingCampaigns MarketingCampaign[]
  marketingTasks     MarketingTask[]
  marketingLeads     MarketingLead[]
  marketingActivities MarketingActivity[]
  marketingKPIs      MarketingKPI[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([businessId, code])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  level       Int          @unique
  description String?
  isSystem    Boolean      @default(true)
  permissions RolePermission[]
  employees   Employee[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String            @id @default(cuid())
  code        String            @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Employee {
  id                 String           @id @default(cuid())
  organizationId     String
  businessId         String
  departmentId       String?
  teamId             String?
  roleId             String
  reportsToId        String?
  firstName          String
  lastName           String
  employeeCode       String?          @unique
  fullName           String?
  level              Int?
  email              String           @unique
  passwordHash       String
  isActive           Boolean          @default(true)
  designation        String?
  organization       Organization     @relation(fields: [organizationId], references: [id])
  business           Business         @relation(fields: [businessId], references: [id])
  department         Department?      @relation(fields: [departmentId], references: [id])
  team               Team?            @relation(fields: [teamId], references: [id])
  role               Role             @relation(fields: [roleId], references: [id])
  reportsTo          Employee?        @relation("EmployeeReports", fields: [reportsToId], references: [id])
  directReports      Employee[]       @relation("EmployeeReports")

  // New additive manager fields for staged migration (do not remove `reportsToId` yet)
  managerId          String?
  manager            Employee?        @relation("EmployeeReportsByManager", fields: [managerId], references: [id])
  subordinates       Employee[]       @relation("EmployeeReportsByManager")
  hierarchyAsEmployee EmployeeHierarchy[] @relation("HierarchyEmployee")
  hierarchyAsManager EmployeeHierarchy[] @relation("HierarchyManager")
  perspectivesAsUser Perspective[]
  perspectivesAsTarget Perspective[] @relation("PerspectiveTarget")
  perspectiveSessionsAsUser PerspectiveSession[] @relation("PerspectiveSessionUser")
  sessions           Session[] @relation("SessionUser")
  notificationsAsActor Notification[] @relation("NotificationActor")
  notificationsAsRecipient Notification[] @relation("NotificationRecipient")
  tasksOwned         Task[]           @relation("TaskAssignee")
  tasksCreated       Task[]           @relation("TaskCreator")
  documentsCreated   Document[]       @relation("DocumentCreator")
  activities         Activity[]       @relation("ActivityActor")
  auditLogs          AuditLog[]       @relation("AuditActor")
  marketingCampaignsCreated MarketingCampaign[] @relation("MarketingCampaignCreator")
  marketingCampaignsAssigned MarketingCampaign[] @relation("MarketingCampaignAssignee")
  marketingTasksCreated MarketingTask[] @relation("MarketingTaskCreator")
  marketingTasksAssigned MarketingTask[] @relation("MarketingTaskAssignee")
  marketingLeadsCreated MarketingLead[] @relation("MarketingLeadCreator")
  marketingLeadsAssigned MarketingLead[] @relation("MarketingLeadAssignee")
  marketingActivities MarketingActivity[] @relation("MarketingActivityActor")
  marketingKPIs MarketingKPI[] @relation("MarketingKPIEmployee")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([businessId])
  @@index([departmentId])
  @@index([teamId])
  @@index([reportsToId])
  @@index([managerId])
}

model EmployeeHierarchy {
  id         String   @id @default(cuid())
  employeeId String
  managerId  String
  depth      Int
  employee   Employee @relation("HierarchyEmployee", fields: [employeeId], references: [id])
  manager    Employee @relation("HierarchyManager", fields: [managerId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([employeeId, managerId, depth])
  @@index([employeeId])
  @@index([managerId])
}

model Perspective {
  id                    String           @id @default(cuid())
  userId                String
  currentPerspectiveId  String
  perspectiveType       PerspectiveType
  user                  Employee         @relation(fields: [userId], references: [id])
  currentPerspective    Employee         @relation("PerspectiveTarget", fields: [currentPerspectiveId], references: [id])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([userId, currentPerspectiveId])
  @@index([userId])
  @@index([currentPerspectiveId])
}

// Additive models for non-destructive migration: session, notification, perspective sessions
model PerspectiveSession {
  id                  String                @id @default(cuid())
  userId              String
  perspectiveType     PerspectiveTargetType
  perspectiveTargetId String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  user                Employee              @relation("PerspectiveSessionUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([perspectiveTargetId])
}

model Session {
  id         String    @id @default(cuid())
  userId     String?
  token      String    @unique
  data       Json?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  user       Employee? @relation("SessionUser", fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id         String    @id @default(cuid())
  businessId String?
  actorId    String?
  recipientId String?
  type       String
  payload    Json?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())

  business   Business? @relation("NotificationBusiness", fields: [businessId], references: [id])
  actor      Employee? @relation("NotificationActor", fields: [actorId], references: [id])
  recipient  Employee? @relation("NotificationRecipient", fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([businessId])
}

model Task {
  id            String    @id @default(cuid())
  businessId    String
  departmentId  String?
  teamId        String?
  assigneeId    String?
  createdById   String?
  title         String
  description   String?
  status        String
  priority      String
  dueDate       DateTime?
  business      Business  @relation(fields: [businessId], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  team          Team?     @relation(fields: [teamId], references: [id])
  assignee      Employee? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy     Employee? @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([businessId])
  @@index([assigneeId])
}

model Document {
  id          String    @id @default(cuid())
  businessId  String
  createdById String?
  title       String
  kind        String
  storageUrl  String
  business    Business  @relation(fields: [businessId], references: [id])
  createdBy   Employee? @relation("DocumentCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Activity {
  id            String         @id @default(cuid())
  businessId    String
  actorId       String?
  targetType    String
  targetId      String?
  action        ActivityAction
  metadata      Json?
  business      Business       @relation(fields: [businessId], references: [id])
  actor         Employee?      @relation("ActivityActor", fields: [actorId], references: [id])
  createdAt     DateTime       @default(now())

  @@index([businessId])
  @@index([actorId])
}

model AuditLog {
  id             String         @id @default(cuid())
  businessId     String?
  actorId        String?
  action         ActivityAction
  entityType     String
  entityId       String?
  before         Json?
  after          Json?
  perspectiveId  String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())
  business       Business?      @relation(fields: [businessId], references: [id])
  actor          Employee?      @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([businessId])
}

model MarketingCampaign {
  id             String                  @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  createdById    String?
  assignedToId   String?
  name           String
  description    String?
  channel        String
  status         MarketingCampaignStatus @default(DRAFT)
  startDate      DateTime?
  endDate        DateTime?
  budget         Decimal?                @db.Decimal(14, 2)
  budgetSpent    Decimal?                @db.Decimal(14, 2)
  targetLeads    Int?
  actualLeads    Int                     @default(0)
  successMetric  String?
  organization   Organization            @relation(fields: [organizationId], references: [id])
  business       Business                @relation(fields: [businessId], references: [id])
  team           Team?                   @relation(fields: [teamId], references: [id])
  createdBy      Employee?               @relation("MarketingCampaignCreator", fields: [createdById], references: [id])
  assignedTo     Employee?               @relation("MarketingCampaignAssignee", fields: [assignedToId], references: [id])
  tasks          MarketingTask[]
  leads          MarketingLead[]
  activities     MarketingActivity[]
  kpis           MarketingKPI[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([assignedToId])
  @@index([status])
}

model MarketingTask {
  id             String              @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  campaignId     String?
  assignedToId   String?
  createdById    String?
  title          String
  description    String?
  status         MarketingTaskStatus @default(TODO)
  priority       String              @default("medium")
  dueDate        DateTime?
  completedAt    DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id])
  business       Business            @relation(fields: [businessId], references: [id])
  team           Team?               @relation(fields: [teamId], references: [id])
  campaign       MarketingCampaign?  @relation(fields: [campaignId], references: [id])
  assignedTo     Employee?           @relation("MarketingTaskAssignee", fields: [assignedToId], references: [id])
  createdBy      Employee?           @relation("MarketingTaskCreator", fields: [createdById], references: [id])
  activities     MarketingActivity[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([campaignId])
  @@index([assignedToId])
  @@index([status])
}

model MarketingLead {
  id             String              @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  campaignId     String?
  createdById    String?
  assignedToId   String?
  name           String
  email          String?
  phone          String?
  source         String
  status         MarketingLeadStatus @default(NEW)
  estimatedValue Decimal?            @db.Decimal(14, 2)
  notes          String?
  convertedAt    DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id])
  business       Business            @relation(fields: [businessId], references: [id])
  team           Team?               @relation(fields: [teamId], references: [id])
  campaign       MarketingCampaign?  @relation(fields: [campaignId], references: [id])
  createdBy      Employee?           @relation("MarketingLeadCreator", fields: [createdById], references: [id])
  assignedTo     Employee?           @relation("MarketingLeadAssignee", fields: [assignedToId], references: [id])
  activities     MarketingActivity[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([campaignId])
  @@index([assignedToId])
  @@index([status])
}

model MarketingActivity {
  id             String                @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  campaignId     String?
  taskId         String?
  leadId         String?
  actorId        String?
  type           MarketingActivityType
  title          String
  description    String?
  reportDate     DateTime              @default(now())
  metadata       Json?
  organization   Organization          @relation(fields: [organizationId], references: [id])
  business       Business              @relation(fields: [businessId], references: [id])
  team           Team?                 @relation(fields: [teamId], references: [id])
  campaign       MarketingCampaign?    @relation(fields: [campaignId], references: [id])
  task           MarketingTask?        @relation(fields: [taskId], references: [id])
  lead           MarketingLead?        @relation(fields: [leadId], references: [id])
  actor          Employee?             @relation("MarketingActivityActor", fields: [actorId], references: [id])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([campaignId])
  @@index([taskId])
  @@index([leadId])
  @@index([actorId])
  @@index([type])
}

model MarketingKPI {
  id             String           @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  employeeId     String?
  campaignId     String?
  metricType     MarketingKPIType
  name           String
  value          Decimal          @db.Decimal(14, 2)
  target         Decimal?         @db.Decimal(14, 2)
  periodStart    DateTime
  periodEnd      DateTime
  organization   Organization     @relation(fields: [organizationId], references: [id])
  business       Business         @relation(fields: [businessId], references: [id])
  team           Team?            @relation(fields: [teamId], references: [id])
  employee       Employee?        @relation("MarketingKPIEmployee", fields: [employeeId], references: [id])
  campaign       MarketingCampaign? @relation(fields: [campaignId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([employeeId])
  @@index([campaignId])
  @@index([metricType])
}

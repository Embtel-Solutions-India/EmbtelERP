generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ASSIGNMENT_CHANGE
  PERSPECTIVE_SWITCH
  LOGIN
  LOGOUT
}

enum PerspectiveType {
  SELF
  DESCENDANT
  BUSINESS
  DEPARTMENT
  TEAM
  ALL
}

model Organization {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  businesses Business[]
  employees  Employee[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Business {
  id             String       @id @default(cuid())
  organizationId  String
  name           String
  code           String       @unique
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  departments    Department[]
  teams          Team[]
  employees      Employee[]
  notifications  Notification[] @relation("NotificationBusiness")
  tasks          Task[]
  documents     Document[]
  activities    Activity[]
  auditLogs     AuditLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Department {
  id              String       @id @default(cuid())
  businessId      String
  name            String
  code            String
  parentId        String?
  isActive        Boolean      @default(true)
  business        Business     @relation(fields: [businessId], references: [id])
  parent          Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children        Department[] @relation("DepartmentTree")
  teams           Team[]
  employees       Employee[]
  tasks           Task[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([businessId, code])
}

model Team {
  id           String      @id @default(cuid())
  businessId   String
  departmentId String?
  name         String
  code         String
  isActive     Boolean     @default(true)
  business     Business    @relation(fields: [businessId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  tasks        Task[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([businessId, code])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  level       Int          @unique
  description String?
  isSystem    Boolean      @default(true)
  permissions RolePermission[]
  employees   Employee[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String            @id @default(cuid())
  code        String            @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Employee {
  id                 String           @id @default(cuid())
  organizationId     String
  businessId         String
  departmentId       String?
  teamId             String?
  roleId             String
  reportsToId        String?
  firstName          String
  lastName           String
  employeeCode       String?          @unique
  fullName           String?
  level              Int?
  email              String           @unique
  passwordHash       String
  isActive           Boolean          @default(true)
  designation        String?
  organization       Organization     @relation(fields: [organizationId], references: [id])
  business           Business         @relation(fields: [businessId], references: [id])
  department         Department?      @relation(fields: [departmentId], references: [id])
  team               Team?            @relation(fields: [teamId], references: [id])
  role               Role             @relation(fields: [roleId], references: [id])
  reportsTo          Employee?        @relation("EmployeeReports", fields: [reportsToId], references: [id])
  directReports      Employee[]       @relation("EmployeeReports")
  hierarchyAsEmployee EmployeeHierarchy[] @relation("HierarchyEmployee")
  hierarchyAsManager EmployeeHierarchy[] @relation("HierarchyManager")
  perspectivesAsUser Perspective[]
  perspectivesAsTarget Perspective[] @relation("PerspectiveTarget")
  perspectiveSessionsAsUser PerspectiveSession[] @relation("PerspectiveSessionUser")
  perspectiveSessionsAsTarget PerspectiveSession[] @relation("PerspectiveSessionTarget")
  sessions           Session[] @relation("SessionUser")
  notificationsAsActor Notification[] @relation("NotificationActor")
  notificationsAsRecipient Notification[] @relation("NotificationRecipient")
  tasksOwned         Task[]           @relation("TaskAssignee")
  tasksCreated       Task[]           @relation("TaskCreator")
  documentsCreated   Document[]       @relation("DocumentCreator")
  activities         Activity[]       @relation("ActivityActor")
  auditLogs          AuditLog[]       @relation("AuditActor")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([businessId])
  @@index([departmentId])
  @@index([teamId])
  @@index([reportsToId])
}

model EmployeeHierarchy {
  id         String   @id @default(cuid())
  employeeId String
  managerId  String
  depth      Int
  employee   Employee @relation("HierarchyEmployee", fields: [employeeId], references: [id])
  manager    Employee @relation("HierarchyManager", fields: [managerId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([employeeId, managerId, depth])
  @@index([employeeId])
  @@index([managerId])
}

model Perspective {
  id                    String           @id @default(cuid())
  userId                String
  currentPerspectiveId  String
  perspectiveType       PerspectiveType
  user                  Employee         @relation(fields: [userId], references: [id])
  currentPerspective    Employee         @relation("PerspectiveTarget", fields: [currentPerspectiveId], references: [id])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([userId, currentPerspectiveId])
  @@index([userId])
  @@index([currentPerspectiveId])
}

// Additive models for non-destructive migration: session, notification, perspective sessions
model PerspectiveSession {
  id             String    @id @default(cuid())
  userId         String

  perspectiveId  String
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  user           Employee  @relation("PerspectiveSessionUser", fields: [userId], references: [id])
  perspective    Employee  @relation("PerspectiveSessionTarget", fields: [perspectiveId], references: [id])

  @@index([userId])
  @@index([perspectiveId])
}

model Session {
  id         String    @id @default(cuid())
  userId     String?
  token      String    @unique
  data       Json?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  user       Employee? @relation("SessionUser", fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id         String    @id @default(cuid())
  businessId String?
  actorId    String?
  recipientId String?
  type       String
  payload    Json?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())

  business   Business? @relation("NotificationBusiness", fields: [businessId], references: [id])
  actor      Employee? @relation("NotificationActor", fields: [actorId], references: [id])
  recipient  Employee? @relation("NotificationRecipient", fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([businessId])
}

model Task {
  id            String    @id @default(cuid())
  businessId    String
  departmentId  String?
  teamId        String?
  assigneeId    String?
  createdById   String?
  title         String
  description   String?
  status        String
  priority      String
  dueDate       DateTime?
  business      Business  @relation(fields: [businessId], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  team          Team?     @relation(fields: [teamId], references: [id])
  assignee      Employee? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy     Employee? @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([businessId])
  @@index([assigneeId])
}

model Document {
  id          String    @id @default(cuid())
  businessId  String
  createdById String?
  title       String
  kind        String
  storageUrl  String
  business    Business  @relation(fields: [businessId], references: [id])
  createdBy   Employee? @relation("DocumentCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Activity {
  id            String         @id @default(cuid())
  businessId    String
  actorId       String?
  targetType    String
  targetId      String?
  action        ActivityAction
  metadata      Json?
  business      Business       @relation(fields: [businessId], references: [id])
  actor         Employee?      @relation("ActivityActor", fields: [actorId], references: [id])
  createdAt     DateTime       @default(now())

  @@index([businessId])
  @@index([actorId])
}

model AuditLog {
  id             String         @id @default(cuid())
  businessId     String?
  actorId        String?
  action         ActivityAction
  entityType     String
  entityId       String?
  before         Json?
  after          Json?
  perspectiveId  String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())
  business       Business?      @relation(fields: [businessId], references: [id])
  actor          Employee?      @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([businessId])
}

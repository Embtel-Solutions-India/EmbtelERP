generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  PAYMENT_STATUS_CHANGE
  ASSIGNMENT_CHANGE
  PERSPECTIVE_SWITCH
  LOGIN
  LOGOUT
}

enum PerspectiveType {
  SELF
  DESCENDANT
  BUSINESS
  DEPARTMENT
  TEAM
  ALL
  BUSINESS_OWNER
  HEAD
  VERTICAL
  TEAM_MANAGER
  EMPLOYEE
}

enum PerspectiveTargetType {
  ORGANIZATION
  BUSINESS
  BUSINESS_OWNER
  DEPARTMENT
  TEAM
  EMPLOYEE
  VERTICAL
  HEAD
  MANAGER
  INTERN
}

enum MarketingCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum MarketingTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum MarketingLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum SalesLeadStatus {
  NEW
  CONTACTED
  CONSULTATION_SCHEDULED
  DOCUMENTS_REQUESTED
  QUALIFIED
  CONVERTED
  TRANSFERRED
  LOST
}

enum SalesLeadPaymentStatus {
  INITIATED
  IN_PROGRESS
  DONE
  PARTIALLY_DONE
}

enum VisaCategory {
  H1B
  L1A
  L1B
  O1
  TN
  E3
  EB1
  EB2_NIW
  FAMILY_GREEN_CARD
  MARRIAGE_BASED
  BUSINESS_VISA
  VISITOR_VISA
  PERMANENT_RESIDENCY
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
}

enum LeadCurrentStatus {
  STUDENT
  WORKER
  BUSINESS_OWNER
}

enum SalesTaskType {
  CALL
  WHATSAPP_FOLLOWUP
  EMAIL_FOLLOWUP
  CONSULTATION_MEETING
  DOCUMENT_COLLECTION
  PAYMENT_FOLLOWUP
  VISA_ELIGIBILITY_DISCUSSION
  LEAD_NURTURING
  CLIENT_MEETING
  INTERNAL_DISCUSSION
}

enum SalesTaskResult {
  CONNECTED
  NO_RESPONSE
  INTERESTED
  NOT_INTERESTED
  CALL_BACK_LATER
  CONSULTATION_BOOKED
  DOCUMENTS_RECEIVED
  PAYMENT_RECEIVED
  CONVERTED
  LOST_LEAD
}

enum SalesTaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MarketingActivityType {
  SOCIAL_MEDIA
  LEAD_GENERATION
  DAILY_REPORT
  TASK_UPDATE
  CAMPAIGN_UPDATE
  OTHER
}

enum MarketingKPIType {
  LEADS_GENERATED
  CAMPAIGN_SUCCESS
  TASK_COMPLETION
  PRODUCTIVITY
  BUDGET_UTILIZATION
  CUSTOM
}

model Organization {
  id                  String              @id @default(cuid())
  name                String
  slug                String              @unique
  businesses          Business[]
  employees           Employee[]
  marketingCampaigns  MarketingCampaign[]
  marketingTasks      MarketingTask[]
  marketingLeads      MarketingLead[]
  marketingActivities MarketingActivity[]
  marketingKPIs       MarketingKPI[]
  salesLeads          SalesLead[]
  salesTasks          SalesTask[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model Business {
  id                  String              @id @default(cuid())
  organizationId      String
  name                String
  code                String              @unique
  isActive            Boolean             @default(true)
  organization        Organization        @relation(fields: [organizationId], references: [id])
  departments         Department[]
  teams               Team[]
  verticals           Vertical[]
  employees           Employee[]
  notifications       Notification[]      @relation("NotificationBusiness")
  tasks               Task[]
  documents           Document[]
  activities          Activity[]
  auditLogs           AuditLog[]
  marketingCampaigns  MarketingCampaign[]
  marketingTasks      MarketingTask[]
  marketingLeads      MarketingLead[]
  marketingActivities MarketingActivity[]
  marketingKPIs       MarketingKPI[]
  salesLeads          SalesLead[]
  salesTasks          SalesTask[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model Department {
  id         String       @id @default(cuid())
  businessId String
  name       String
  code       String
  parentId   String?
  isActive   Boolean      @default(true)
  business   Business     @relation(fields: [businessId], references: [id])
  parent     Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children   Department[] @relation("DepartmentTree")
  teams      Team[]
  employees  Employee[]
  tasks      Task[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([businessId, code])
}

model Vertical {
  id                  String              @id @default(cuid())
  businessId          String
  name                String
  code                String
  isActive            Boolean             @default(true)
  business            Business            @relation(fields: [businessId], references: [id])
  teams               Team[]
  employees           Employee[]
  tasks               Task[]
  marketingCampaigns  MarketingCampaign[]
  marketingTasks      MarketingTask[]
  marketingLeads      MarketingLead[]
  marketingActivities MarketingActivity[]
  marketingKPIs       MarketingKPI[]
  salesLeads          SalesLead[]
  salesTasks          SalesTask[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([businessId, code])
}

model Team {
  id                  String              @id @default(cuid())
  businessId          String
  departmentId        String?
  verticalId          String?
  name                String
  code                String
  isActive            Boolean             @default(true)
  business            Business            @relation(fields: [businessId], references: [id])
  department          Department?         @relation(fields: [departmentId], references: [id])
  vertical            Vertical?           @relation(fields: [verticalId], references: [id])
  employees           Employee[]
  tasks               Task[]
  marketingCampaigns  MarketingCampaign[]
  marketingTasks      MarketingTask[]
  marketingLeads      MarketingLead[]
  marketingActivities MarketingActivity[]
  marketingKPIs       MarketingKPI[]
  salesLeads          SalesLead[]
  salesTasks          SalesTask[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([businessId, code])
}

model Role {
  id          String           @id @default(cuid())
  name        String
  level       Int              @unique
  description String?
  isSystem    Boolean          @default(true)
  permissions RolePermission[]
  employees   Employee[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Employee {
  id                         String               @id @default(cuid())
  organizationId             String
  businessId                 String
  departmentId               String?
  teamId                     String?
  verticalId                 String?
  roleId                     String
  firstName                  String
  lastName                   String
  employeeCode               String?              @unique
  fullName                   String?
  level                      Int?
  email                      String               @unique
  passwordHash               String
  isActive                   Boolean              @default(true)
  designation                String?
  organization               Organization         @relation(fields: [organizationId], references: [id])
  business                   Business             @relation(fields: [businessId], references: [id])
  department                 Department?          @relation(fields: [departmentId], references: [id])
  team                       Team?                @relation(fields: [teamId], references: [id])
  vertical                   Vertical?            @relation(fields: [verticalId], references: [id])
  role                       Role                 @relation(fields: [roleId], references: [id])
  managerId                  String?
  manager                    Employee?            @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates               Employee[]           @relation("ManagerSubordinates")
  hierarchyAsEmployee        EmployeeHierarchy[]  @relation("HierarchyEmployee")
  hierarchyAsManager         EmployeeHierarchy[]  @relation("HierarchyManager")
  perspectiveSessionsAsUser  PerspectiveSession[] @relation("PerspectiveSessionUser")
  sessions                   Session[]            @relation("SessionUser")
  notificationsAsActor       Notification[]       @relation("NotificationActor")
  notificationsAsRecipient   Notification[]       @relation("NotificationRecipient")
  tasksOwned                 Task[]               @relation("TaskAssignee")
  tasksCreated               Task[]               @relation("TaskCreator")
  documentsCreated           Document[]           @relation("DocumentCreator")
  activities                 Activity[]           @relation("ActivityActor")
  auditLogs                  AuditLog[]           @relation("AuditActor")
  marketingCampaignsCreated  MarketingCampaign[]  @relation("MarketingCampaignCreator")
  marketingCampaignsAssigned MarketingCampaign[]  @relation("MarketingCampaignAssignee")
  marketingTasksCreated      MarketingTask[]      @relation("MarketingTaskCreator")
  marketingTasksAssigned     MarketingTask[]      @relation("MarketingTaskAssignee")
  marketingLeadsCreated      MarketingLead[]      @relation("MarketingLeadCreator")
  marketingLeadsAssigned     MarketingLead[]      @relation("MarketingLeadAssignee")
  salesLeadsCreated          SalesLead[]          @relation("SalesLeadCreator")
  salesLeadsAssigned         SalesLead[]          @relation("SalesLeadAssignee")
  salesTasksCreated          SalesTask[]          @relation("SalesTaskCreator")
  salesTasksAssigned         SalesTask[]          @relation("SalesTaskAssignee")
  marketingActivities        MarketingActivity[]  @relation("MarketingActivityActor")
  marketingKPIs              MarketingKPI[]       @relation("MarketingKPIEmployee")
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  @@index([businessId])
  @@index([departmentId])
  @@index([teamId])
  @@index([verticalId])
  @@index([managerId])
}

model EmployeeHierarchy {
  id         String   @id @default(cuid())
  employeeId String
  managerId  String
  depth      Int
  employee   Employee @relation("HierarchyEmployee", fields: [employeeId], references: [id])
  manager    Employee @relation("HierarchyManager", fields: [managerId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([employeeId, managerId, depth])
  @@index([employeeId])
  @@index([managerId])
}

model PerspectiveSession {
  id                  String                @id @default(cuid())
  userId              String
  perspectiveType     PerspectiveTargetType
  perspectiveTargetId String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  user Employee @relation("PerspectiveSessionUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([perspectiveTargetId])
}

model Session {
  id        String    @id @default(cuid())
  userId    String?
  token     String    @unique
  data      Json?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user Employee? @relation("SessionUser", fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id          String   @id @default(cuid())
  businessId  String?
  actorId     String?
  recipientId String?
  type        String
  payload     Json?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  business  Business? @relation("NotificationBusiness", fields: [businessId], references: [id])
  actor     Employee? @relation("NotificationActor", fields: [actorId], references: [id])
  recipient Employee? @relation("NotificationRecipient", fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([businessId])
}

model Task {
  id           String      @id @default(cuid())
  businessId   String
  departmentId String?
  teamId       String?
  verticalId   String?
  assigneeId   String?
  createdById  String?
  title        String
  description  String?
  status       String
  priority     String
  dueDate      DateTime?
  business     Business    @relation(fields: [businessId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  team         Team?       @relation(fields: [teamId], references: [id])
  vertical     Vertical?   @relation(fields: [verticalId], references: [id])
  assignee     Employee?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy    Employee?   @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([businessId])
  @@index([assigneeId])
  @@index([verticalId])
}

model Document {
  id          String    @id @default(cuid())
  businessId  String
  createdById String?
  title       String
  kind        String
  storageUrl  String
  business    Business  @relation(fields: [businessId], references: [id])
  createdBy   Employee? @relation("DocumentCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Activity {
  id         String         @id @default(cuid())
  businessId String
  actorId    String?
  targetType String
  targetId   String?
  action     ActivityAction
  metadata   Json?
  business   Business       @relation(fields: [businessId], references: [id])
  actor      Employee?      @relation("ActivityActor", fields: [actorId], references: [id])
  createdAt  DateTime       @default(now())

  @@index([businessId])
  @@index([actorId])
}

model AuditLog {
  id            String         @id @default(cuid())
  businessId    String?
  actorId       String?
  action        ActivityAction
  entityType    String
  entityName    String?
  entityId      String?
  before        Json?
  after         Json?
  perspectiveId String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime       @default(now())
  business      Business?      @relation(fields: [businessId], references: [id])
  actor         Employee?      @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([businessId])
}

model MarketingCampaign {
  id             String                  @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  verticalId     String?
  createdById    String?
  assignedToId   String?
  name           String
  description    String?
  channel        String
  status         MarketingCampaignStatus @default(DRAFT)
  startDate      DateTime?
  endDate        DateTime?
  budget         Decimal?                @db.Decimal(14, 2)
  budgetSpent    Decimal?                @db.Decimal(14, 2)
  targetLeads    Int?
  actualLeads    Int                     @default(0)
  successMetric  String?
  organization   Organization            @relation(fields: [organizationId], references: [id])
  business       Business                @relation(fields: [businessId], references: [id])
  team           Team?                   @relation(fields: [teamId], references: [id])
  vertical       Vertical?               @relation(fields: [verticalId], references: [id])
  createdBy      Employee?               @relation("MarketingCampaignCreator", fields: [createdById], references: [id])
  assignedTo     Employee?               @relation("MarketingCampaignAssignee", fields: [assignedToId], references: [id])
  tasks          MarketingTask[]
  leads          MarketingLead[]
  activities     MarketingActivity[]
  kpis           MarketingKPI[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([verticalId])
  @@index([assignedToId])
  @@index([status])
}

model MarketingTask {
  id             String              @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  verticalId     String?
  campaignId     String?
  assignedToId   String?
  createdById    String?
  title          String
  description    String?
  status         MarketingTaskStatus @default(TODO)
  priority       String              @default("medium")
  dueDate        DateTime?
  completedAt    DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id])
  business       Business            @relation(fields: [businessId], references: [id])
  team           Team?               @relation(fields: [teamId], references: [id])
  vertical       Vertical?           @relation(fields: [verticalId], references: [id])
  campaign       MarketingCampaign?  @relation(fields: [campaignId], references: [id])
  assignedTo     Employee?           @relation("MarketingTaskAssignee", fields: [assignedToId], references: [id])
  createdBy      Employee?           @relation("MarketingTaskCreator", fields: [createdById], references: [id])
  activities     MarketingActivity[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([verticalId])
  @@index([campaignId])
  @@index([assignedToId])
  @@index([status])
}

model MarketingLead {
  id             String              @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  verticalId     String?
  campaignId     String?
  createdById    String?
  assignedToId   String?
  name           String
  email          String?
  phone          String?
  source         String
  status         MarketingLeadStatus @default(NEW)
  estimatedValue Decimal?            @db.Decimal(14, 2)
  notes          String?
  convertedAt    DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id])
  business       Business            @relation(fields: [businessId], references: [id])
  team           Team?               @relation(fields: [teamId], references: [id])
  vertical       Vertical?           @relation(fields: [verticalId], references: [id])
  campaign       MarketingCampaign?  @relation(fields: [campaignId], references: [id])
  createdBy      Employee?           @relation("MarketingLeadCreator", fields: [createdById], references: [id])
  assignedTo     Employee?           @relation("MarketingLeadAssignee", fields: [assignedToId], references: [id])
  activities     MarketingActivity[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([verticalId])
  @@index([campaignId])
  @@index([assignedToId])
  @@index([status])
}

model MarketingActivity {
  id             String                @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  verticalId     String?
  campaignId     String?
  taskId         String?
  leadId         String?
  actorId        String?
  type           MarketingActivityType
  title          String
  description    String?
  reportDate     DateTime              @default(now())
  metadata       Json?
  organization   Organization          @relation(fields: [organizationId], references: [id])
  business       Business              @relation(fields: [businessId], references: [id])
  team           Team?                 @relation(fields: [teamId], references: [id])
  vertical       Vertical?             @relation(fields: [verticalId], references: [id])
  campaign       MarketingCampaign?    @relation(fields: [campaignId], references: [id])
  task           MarketingTask?        @relation(fields: [taskId], references: [id])
  lead           MarketingLead?        @relation(fields: [leadId], references: [id])
  actor          Employee?             @relation("MarketingActivityActor", fields: [actorId], references: [id])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([verticalId])
  @@index([campaignId])
  @@index([taskId])
  @@index([leadId])
  @@index([actorId])
  @@index([type])
}

model MarketingKPI {
  id             String             @id @default(cuid())
  organizationId String
  businessId     String
  teamId         String?
  verticalId     String?
  employeeId     String?
  campaignId     String?
  metricType     MarketingKPIType
  name           String
  value          Decimal            @db.Decimal(14, 2)
  target         Decimal?           @db.Decimal(14, 2)
  periodStart    DateTime
  periodEnd      DateTime
  organization   Organization       @relation(fields: [organizationId], references: [id])
  business       Business           @relation(fields: [businessId], references: [id])
  team           Team?              @relation(fields: [teamId], references: [id])
  vertical       Vertical?          @relation(fields: [verticalId], references: [id])
  employee       Employee?          @relation("MarketingKPIEmployee", fields: [employeeId], references: [id])
  campaign       MarketingCampaign? @relation(fields: [campaignId], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([verticalId])
  @@index([employeeId])
  @@index([campaignId])
  @@index([metricType])
}

model SalesLead {
  id                        String                 @id @default(cuid())
  leadCode                  String                 @unique
  organizationId            String
  businessId                String
  teamId                    String?
  verticalId                String?
  createdById               String?
  assignedToId              String?
  // Section 1: Lead Information
  name                      String
  company                   String?
  email                     String?
  phone                     String?
  whatsappNumber            String?
  countryOfResidence        String?
  nationality               String?
  visaCategory              VisaCategory?
  source                    String
  priorityLevel             PriorityLevel          @default(MEDIUM)
  // Section 2: Immigration Requirement
  interestedVisa            VisaCategory?
  currentStatus             LeadCurrentStatus?
  education                 String?
  workExperienceYears       Int?
  familyImmigrationRequired Boolean                @default(false)
  budgetAvailable           Decimal?               @db.Decimal(14, 2)
  urgencyLevel              PriorityLevel          @default(MEDIUM)
  // Section 3: Lead Qualification
  leadScore                 Int                    @default(0)
  priority                  String                 @default("warm") // Interested Level: hot / warm / cold
  expectedInvestment        Decimal?               @db.Decimal(14, 2)
  consultationRequired      Boolean                @default(false)
  consultationDate          DateTime?
  notes                     String? // Remarks
  // Section 4: Payment
  paymentStatus             SalesLeadPaymentStatus @default(INITIATED)
  paymentAmount             Decimal?               @db.Decimal(14, 2)
  // Section 5: Status / lifecycle
  status                    SalesLeadStatus        @default(NEW)
  estimatedValue            Decimal?               @db.Decimal(14, 2)
  convertedAt               DateTime?
  transferredAt             DateTime?
  organization              Organization           @relation(fields: [organizationId], references: [id])
  business                  Business               @relation(fields: [businessId], references: [id])
  team                      Team?                  @relation(fields: [teamId], references: [id])
  vertical                  Vertical?              @relation(fields: [verticalId], references: [id])
  createdBy                 Employee?              @relation("SalesLeadCreator", fields: [createdById], references: [id])
  assignedTo                Employee?              @relation("SalesLeadAssignee", fields: [assignedToId], references: [id])
  salesTasks                SalesTask[]
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([verticalId])
  @@index([assignedToId])
  @@index([status])
  @@index([paymentStatus])
  @@index([priorityLevel])
  @@index([leadScore])
  @@index([createdAt])
}

model SalesTask {
  id               String           @id @default(cuid())
  taskCode         String           @unique
  organizationId   String
  businessId       String
  teamId           String?
  verticalId       String?
  leadId           String?
  assigneeId       String?
  createdById      String?
  title            String
  taskType         SalesTaskType
  description      String?
  status           SalesTaskStatus  @default(TODO)
  priority         PriorityLevel    @default(MEDIUM)
  dueDate          DateTime?
  result           SalesTaskResult?
  nextFollowUpDate DateTime?
  notes            String?
  completedAt      DateTime?
  organization     Organization     @relation(fields: [organizationId], references: [id])
  business         Business         @relation(fields: [businessId], references: [id])
  team             Team?            @relation(fields: [teamId], references: [id])
  vertical         Vertical?        @relation(fields: [verticalId], references: [id])
  lead             SalesLead?       @relation(fields: [leadId], references: [id])
  assignee         Employee?        @relation("SalesTaskAssignee", fields: [assigneeId], references: [id])
  createdBy        Employee?        @relation("SalesTaskCreator", fields: [createdById], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([teamId])
  @@index([verticalId])
  @@index([leadId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([nextFollowUpDate])
}

model DashboardConfig {
  id        String   @id @default(cuid())
  role      String // e.g. "sales_intern", "sales_executive", "sales_head", "marketing_intern", "marketing_executive", "marketing_manager", "documentation_executive", "documentation_manager", "vertical_manager", "immigration_head", "evaluation_head", "hr_manager", "business_owner", "super_admin"
  widget    String // e.g. "kpi_cards", "calendar", "activities", "notifications", "quick_actions", "task_summary", "performance", "upcoming_events", ...
  position  Int // Order position
  priority  String // "critical", "high", "medium", "low"
  colSpan   Json? // { xs: 1, sm: 2, md: 3, lg: 4, xl: 5 }
  height    String? // "small", "medium", "large"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, widget])
}

enum CalendarEventType {
  MEETING
  FOLLOWUP
  TASK
  DEADLINE
  CAMPAIGN
  DOCUMENT_REVIEW
  APPROVAL
  INTERVIEW
  EMPLOYEE_EVENT
  OTHER
}

enum CalendarEventStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum CalendarEventPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model CalendarEvent {
  id          String                @id @default(cuid())
  title       String
  description String?
  eventType   CalendarEventType     @default(OTHER)
  status      CalendarEventStatus   @default(SCHEDULED)
  priority    CalendarEventPriority @default(MEDIUM)
  date        DateTime
  startTime   String? // "09:00"
  endTime     String? // "10:00"

  // Org scoping
  organizationId String
  businessId     String

  // Ownership
  createdById  String
  assignedToId String?

  // Optional related records (soft links — no FK constraint to keep it flexible)
  relatedLeadId     String?
  relatedTaskId     String?
  relatedEmployeeId String?
  relatedCampaignId String?
  relatedModule     String? // e.g. "lead", "campaign", "task", "employee"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([businessId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([date])
  @@index([eventType])
}
